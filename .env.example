# ===== Commerce (elige uno cuando exista cuenta) =====
# COMMERCE_PROVIDER=shopify | medusa (vacío = catálogo local)
COMMERCE_PROVIDER=
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
MEDUSA_BACKEND_URL=
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# ===== Pagos =====
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ===== CMS editorial =====
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# ===== Base de datos =====
NEXT_PUBLIC_SUPABASE_URL=
# Clave pública de Supabase. Nunca uses aquí service_role.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ===== Imágenes =====
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ===== Analítica =====
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=
NEXT_PUBLIC_SITE_URL=https://www.racorsport.es

# ===== Asistente de producto =====
# Funciona sin IA con respuestas verificadas del catálogo. Para activar el
# modo generativo en streaming, habilita AI Gateway y define estas variables.
RACOR_ASSISTANT_AI=false
RACOR_ASSISTANT_MODEL=openai/gpt-5.4
AI_GATEWAY_API_KEY=
